<!DOCTYPE html>

<html lang="es">
    <head>
        <!-- Meta, start -->
        <meta charset="utf-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <!-- Meta, end -->

        <!-- Bootstrap, start -->
        <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
        <script charset="utf-8" crossorigin="anonymous" defer src="~/lib/bootstrap/js/bootstrap.bundle.min.js" type="text/javascript"></script>
        <!-- Bootstrap, end -->

        <!-- Font Awesome, start -->
        <link href="~/lib/font-awesome/css/all.min.css" rel="stylesheet" type="text/css" />
        <script charset="utf-8" crossorigin="anonymous" defer src="~/lib/font-awesome/js/all.min.js" type="text/javascript"></script>
        <!-- Font Awesome, end -->
        
        <!-- Title, start -->
        <title>
            Indicadores de Chile | @(ViewData["Title"] as string)
        </title>
        <!-- Title, end -->
    </head>
    <body>
        @await Html.PartialAsync(
            partialViewName: "~/Views/Shared/Partial/_Navbar.cshtml"
        )
        
        <main role="main">
            @RenderBody()
        </main>
    </body>
</html>