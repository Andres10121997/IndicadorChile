<!DOCTYPE html>

<html lang="es">
    <head>
        @* meta charset|http-equivalent|viewport *@
        <meta charset="utf-8" />
        <meta http-equiv="content-type" content="text/html; charset=UTF-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />

        @* title *@
        <title>
            Indicadores de Chile | @(ViewData["Title"] as string)
        </title>

        @* preconnect *@
        @* n/a *@

        @* script async *@
        @* n/a *@

        @* CSS que incluye @import *@
        @* n/a *@

        @* JS Sincrónico *@
        @* n/a *@

        @* CSS Sincrónico *@
        <link href="~/lib/bootstrap/css/bootstrap.min.css" hreflang="en" rel="stylesheet" type="text/css" />
        <link href="~/lib/font-awesome/css/all.min.css" hreflang="en" rel="stylesheet" type="text/css" />

        @* preload *@
        @* n/a *@

        @* script defer *@
        <script charset="utf-8" crossorigin="anonymous" defer src="~/lib/bootstrap/js/bootstrap.bundle.min.js" type="text/javascript"></script>
        <script charset="utf-8" crossorigin="anonymous" defer src="~/script/JavaScript/ct.js" type="text/javascript"></script>

        @* prefetch / prerender *@
        @* n/a *@

        @* Todo lo demás ('SEO', meta tags, icons, Open Graph, etc) *@
        <!-- meta tags -->
        <meta name="keywords" content="@(ViewData["Keywords"] as string)">
    </head>
    <body>
        @await Html.PartialAsync(
            partialViewName: "~/Views/Shared/Partial/_Navbar.cshtml"
        )
        
        <main role="main">
            @RenderBody()
        </main>
    </body>
</html>