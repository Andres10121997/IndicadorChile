@model Web.Models.SearchFilterModel
@{
    const string formId = "GetCurrencyForm";
}
@{
    Html.BeginForm(
        actionName: "",
        controllerName: "",
        routeValues: new
        {
            @area = ""
        },
        method: FormMethod.Get,
        antiforgery: true,
        htmlAttributes: new
        {
            @class = "container",
            @id = formId,
            @name = formId
        }
    );
        <fieldset form="@formId">
            <legend>
                Obtener información divisa
            </legend>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        @Html.LabelFor(
                            expression: model => model.Year,
                            htmlAttributes: new
                            {
                                @class = "form-label"
                            }
                        )

                        @Html.EditorFor(
                            expression: model => model.Year,
                            additionalViewData: new
                            {
                                htmlAttributes = new
                                {
                                    @class = "form-control"
                                }
                            }
                        )
                    </div>
                </div>
            </div>
        </fieldset>
    Html.EndForm();
}